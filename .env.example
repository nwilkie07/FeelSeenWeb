# ─── Google OAuth ─────────────────────────────────────────────────────────────
# OAuth 2.0 Web Client ID from Google Cloud Console.
# This is the SAME client ID used by the mobile app.
# Get it from: https://console.cloud.google.com/apis/credentials
#
# In Google Cloud Console, make sure your Web client has these Authorized redirect URIs:
#   http://localhost:5173/auth/callback       (local dev)
#   https://your-domain.pages.dev/auth/callback  (production)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Cloudflare Pages environment variable (set in dashboard, NOT here) ───────
# The client secret must be added in the Cloudflare Pages dashboard:
#   Settings → Environment variables → GOOGLE_CLIENT_SECRET
# It is never stored in this file or committed to source control.
# Get it from Google Cloud Console alongside the client ID above.
#
# GOOGLE_CLIENT_SECRET=GOCSPX-...   ← set this in Cloudflare dashboard only
